graph TD
    A[Start InferenceAsync] --> B{API Key Lezen};
    B --> C{Bestaat Afbeeldingsbestand?};
    C -- Nee --> D[Log Error: Afbeelding Niet Gevonden];
    D --> E[Retourneer Foutmelding];
    E --> Z[Einde];
    C -- Ja --> F[Bouw Inference URL];
    F --> G[Log Request Details];
    G --> H{Probeer request te versturen};
    H -- Poging --> I[Lees Afbeeldingsbytes];
    I --> J[Converteer Afbeelding naar Base64];
    J --> K[Creëer HTTP Content];
    K --> L[Log POST naar URL];
    L --> M[Client POST Async];
    M --> N[Lees Response Body];
    N --> O[Dispose HTTP Content];
    O --> P{Response Succesvol?};
    P -- Ja --> Q[Log Succes];
    Q --> R[Retourneer Response Body];
    R --> Z;
    P -- Nee --> S[Log Fout];
    S --> T[Retourneer Foutmelding met Status Code];
    T --> Z;
    H -- HttpRequestException / IOException --> U[Log Request/IO Error];
    U --> V[Retourneer Foutmelding];
    V --> Z;
    H -- Andere Exception --> W[Log Onverwachte Error];
    W --> X[Retourneer Foutmelding];
    X --> Z;
