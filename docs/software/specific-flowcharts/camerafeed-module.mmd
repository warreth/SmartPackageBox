graph TD
    A[Start TakePicture] --> B{GetOrStartCamera};
    B -- Camera OK --> C[Initialize imageBytes, retries, delay];
    C --> D{Lock lock for Buffer Clearing};
    D --> E[Loop dummyGrabs e.g., 8 times];
    E -- Grab --> F[capture.Grab];
    F --> G[Thread.Sleep 30ms];
    G --> E;
    E -- Loop End --> H[Unlock lock];
    H --> I[Loop maxRetries e.g., 5 times for Frame Capture];
    I -- Attempt --> J{Lock lock for Capture Attempt};
    J --> K{Is capture.IsOpened?};
    K -- No --> L[Log WARNING: Camera not open];
    L --> M[Dispose and nullify _globalCapture];
    M --> N{Try GetOrStartCamera again};
    N -- Success --> O[Continue to Grab Loop];
    N -- Failure --> P[Log ERROR: Failed to re-open];
    P --> Q[Thread.Sleep delayMs];
    Q --> R[Next Attempt in Main Loop];
    K -- Yes --> O;
    O --> S[Loop grabRetries e.g., 3 times];
    S -- Grab Attempt --> T{capture.Grab success?};
    T -- True --> U[new Mat as frameMat];
    U --> V{capture.Retrieve frameMat AND !frameMat.IsEmpty?};
    V -- True --> W[frameMat.ToImage Bgr, byte as img];
    W --> X{img is not null?};
    X -- True --> Y[Convert Emgu.CV Image to ImageSharp Image Rgb24];
    Y --> Z[Loop through pixels to copy data];
    Z --> AA[new MemoryStream as ms];
    AA --> AB[imageSharpImg.Save ms, PngEncoder];
    AB --> AC[imageBytes = ms.ToArray];
    AC --> AD[imageSharpImg.Dispose];
    AD --> AE[frameCapturedSuccessfully = true];
    AE --> AF[currentFrameGrabbed = true];
    AF --> AG[Break Grab Loop];
    V -- False Retrieve failed or empty --> AH[Continue Grab Loop];
    X -- False img is null --> AH;
    T -- False Grab failed --> AH;
    AH --> S;
    S -- Loop End / currentFrameGrabbed --> AI{if currentFrameGrabbed break};
    AI -- True --> AJ[Break Main Capture Loop];
    AI -- False --> AK{if frameCapturedSuccessfully break};
    AK -- True --> AJ;
    AK -- False --> AL{attempt >= maxRetries / 2 AND attempt < maxRetries?};
    AL -- True --> AM[Log WARNING: Attempting re-initialize];
    AM --> AN[Dispose and nullify _globalCapture];
    AN --> AO{Try GetOrStartCamera};
    AO -- Success --> AP[Continue Main Capture Loop];
    AO -- Failure --> AQ[Log ERROR: Failed re-initialize];
    AQ --> AP;
    AL -- False --> AP;
    AP --> J;
    I -- Loop End / frameCapturedSuccessfully --> AJ;
    AJ --> AR[Unlock lock];
    AR --> AS{if frameCapturedSuccessfully break};
    AS -- True --> AT[Return imageBytes];
    AS -- False --> AU[Thread.Sleep delayMs];
    AU --> I;
    I -- All retries failed --> AV{if !frameCapturedSuccessfully};
    AV -- True --> AW[Log ERROR: Failed after maxRetries];
    AW --> AX[Throw InvalidOperationException];
    AX --> AY[End];
    AT --> AY;